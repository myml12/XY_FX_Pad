# macOS / エディタ由来の不要ファイル
.DS_Store
*.swp
*.swo

# ビルド生成物
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.xcodeproj/
*.xcworkspace/
*.app/

# ローカルのJUCE checkout
# ./JUCE にcloneするか、CMakeが見つけられる場所にJUCEをインストールするか、
# -DDJXYPAD_FETCH_JUCE=ON を指定してください。
JUCE/
_deps/

# ローカルの音源テスト素材。著作権のある音源をgitに含めないため除外します。
*.m4a
*.mp3
*.wav
*.aiff
*.aif
*.flac

# 実行ログ / ローカルキャプチャ
*.log
progress/
